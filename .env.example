# ─────────────────────────────────────────────────────────────────────────────
#  Mini NotebookLM — Environment Variables
#  Copy this file to .env and fill in your actual keys.
#  Never commit your real .env file!
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Providers (fill in at least one) ─────────────────────────────────────

# Groq  →  https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# OpenAI  →  https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key-here

# Ollama (local — no key needed, just set the URL)
OLLAMA_BASE_URL=http://localhost:11434

# ── Web Search ────────────────────────────────────────────────────────────────

# Tavily  →  https://tavily.com  (free: 1000 searches/month)
# Purpose-built for RAG — returns clean text, not raw HTML.
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# ── Embedding ─────────────────────────────────────────────────────────────────

# Default embedding model (local, no key needed)
# Options: all-MiniLM-L6-v2 | all-mpnet-base-v2 | e5-large-v2
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Storage paths (optional overrides) ───────────────────────────────────────

FAISS_INDEX_PATH=data/vector_store
SQLITE_DB_PATH=data/sources.db
GRAPH_STORAGE_PATH=data/graph

# ── App Config ────────────────────────────────────────────────────────────────

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
