# Ensure consistent line endings
* text=auto eol=lf

# Python
*.py      text eol=lf diff=python

# Data / binary — no diff, no merge
*.pdf     binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.mp3     binary
*.mp4     binary
*.wav     binary
*.db      binary
*.sqlite  binary
*.pkl     binary
*.pt      binary
*.bin     binary
*.faiss   binary

# Config / markup
*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf
*.md      text eol=lf diff=markdown
*.txt     text eol=lf
*.csv     text eol=lf
*.env*    text eol=lf

# Shell
*.sh      text eol=lf
Dockerfile text eol=lf